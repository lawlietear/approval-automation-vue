{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ApprovalTool",
  "version": "0.0.0",
  "identifier": "com.yourcompany.approvaltool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "自动化审批",
        "width": 800,
        "height": 750,
        "minWidth": 700,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "backgroundColor": "#0f0f0f"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "python/dist/ApprovalRunner"
    ]
  }
}
